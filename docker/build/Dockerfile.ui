FROM node:22-alpine AS builder

WORKDIR /src/tailflow-ui

COPY tailflow-ui/package.json tailflow-ui/package-lock.json ./
RUN npm ci

COPY tailflow-ui ./
RUN npm run build

FROM nginx:alpine

COPY --from=builder /src/tailflow-ui/dist /usr/share/nginx/html
COPY tailflow-ui/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
